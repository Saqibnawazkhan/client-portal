# Copy this file to .env.local and fill in your Supabase project's values.
# Find them in Supabase → Project Settings → API.
#   VITE_SUPABASE_URL      = the "Project URL"  (looks like https://xxxx.supabase.co)
#   VITE_SUPABASE_ANON_KEY = the "anon / public" key  (NOT the service_role key)
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# --- SERVER-ONLY (add ONLY in Vercel → Environment Variables, never in the browser) ---
# Used by the /api/create-invite serverless function to generate client invite links.
# Do NOT put a VITE_ prefix on this, and do NOT commit it.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
